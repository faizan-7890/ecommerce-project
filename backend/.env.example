# Veloce Backend Environment Configurations Example
PORT=5000
NODE_ENV=development

# Database Connection (PostgreSQL connection string format)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ecommerce?schema=public"

# JSON Web Token secret key for session credentials hashing
JWT_SECRET="your_high_entropy_jwt_secret_key_here"

# Allowed Cross-Origin Origins
FRONTEND_URL="http://localhost:3000"

# Razorpay Payment Provider Keys
RAZORPAY_KEY_ID="rzp_test_..."
RAZORPAY_KEY_SECRET="your_secret_..."
RAZORPAY_WEBHOOK_SECRET="your_webhook_..."
