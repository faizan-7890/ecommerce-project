# Production Environment Variables Example
# Copy this file to .env.production and fill in the real values

JWT_SECRET="your_high_entropy_jwt_secret_key_here"
FRONTEND_URL="https://www.veloce.example.com"
COOKIE_DOMAIN=".veloce.example.com"

# Razorpay Payment Provider Keys (Production)
RAZORPAY_KEY_ID="rzp_live_..."
RAZORPAY_KEY_SECRET="your_live_secret_..."
RAZORPAY_WEBHOOK_SECRET="your_live_webhook_secret_..."

# Pricing Configuration
TAX_RATE="0.08"
FREE_SHIPPING_THRESHOLD="100"
FLAT_SHIPPING_FEE="10"
