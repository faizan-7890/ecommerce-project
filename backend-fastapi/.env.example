# Veloce Backend (FastAPI) Environment Configuration
PORT=8000

# Database Connection (MySQL)
DATABASE_URL="mysql+pymysql://root:root@localhost:3306/ecommerce"

# JSON Web Token secret key
JWT_SECRET="your_high_entropy_jwt_secret_key_here"

# Clerk Authentication
CLERK_SECRET_KEY="sk_test_..."
CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_JWKS_URL="https://your-clerk-app.clerk.accounts.dev/.well-known/jwks.json"

# Allowed Cross-Origin Origins
FRONTEND_URL="http://localhost:3000"

# Pricing Configuration
TAX_RATE="0.08"
FREE_SHIPPING_THRESHOLD="100"
FLAT_SHIPPING_FEE="10"

# Razorpay Payment Provider Keys
RAZORPAY_KEY_ID="rzp_test_..."
RAZORPAY_KEY_SECRET="your_secret_..."
RAZORPAY_WEBHOOK_SECRET="your_webhook_..."
