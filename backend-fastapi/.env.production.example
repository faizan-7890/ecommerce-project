# Veloce E-Commerce Backend — Production Environment Template

# Server Configuration
PORT=8000
NODE_ENV=production
LOG_LEVEL=info

# Database Configuration (MySQL / AWS RDS / PlanetScale)
DATABASE_URL=mysql+pymysql://db_user:secure_password@mysql-host:3306/veloce_db?charset=utf8mb4

# CORS Security (Allowed origins comma-separated or exact frontend domain)
FRONTEND_URL=https://veloce.yourdomain.com

# Clerk Authentication (Production Instance)
CLERK_SECRET_KEY=sk_live_...
CLERK_PUBLISHABLE_KEY=pk_live_...

# Razorpay Production Payment Credentials
RAZORPAY_KEY_ID=rzp_live_...
RAZORPAY_KEY_SECRET=your_production_razorpay_secret
